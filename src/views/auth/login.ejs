<%- include('../partials/header', {
    title: 'Entrar | AgriFácil',
    description: 'Acesse sua conta na plataforma.',
    bodyClass: 'page-auth',
    page: 'login'
}) %>

<%- include('../partials/navbar') %>

<main class="main-content">
    <section class="page-section auth-shell">
        <div class="auth-grid">
            <div class="hero-panel card surface-card">
                <span class="badge">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                    AgriFácil
                </span>
                <h1 class="page-title">Conecte agricultores a consumidores.</h1>
                <p class="page-lead">Plataforma de venda direta da agricultura familiar. Cadastre seus produtos e alcance clientes sem intermediários.</p>

                <div class="feature-grid">
                    <div class="mini-card">
                        <div class="mini-card__icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <div class="mini-card__title">Acesso seguro</div>
                        <div class="mini-card__text">Autenticação com JWT protegida.</div>
                    </div>
                    <div class="mini-card">
                        <div class="mini-card__icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                        </div>
                        <div class="mini-card__title">Gestão de produtos</div>
                        <div class="mini-card__text">Crie, edite e gerencie seus anúncios.</div>
                    </div>
                    <div class="mini-card">
                        <div class="mini-card__icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                        </div>
                        <div class="mini-card__title">Responsivo</div>
                        <div class="mini-card__text">Funciona em celular, tablet e desktop.</div>
                    </div>
                </div>
            </div>

            <div class="auth-card card surface-card">
                <div class="card-body">
                    <div data-alerts></div>

                    <h2 class="section-heading">Acessar conta</h2>
                    <p class="muted mb-4">Bem-vindo de volta! Digite seus dados para continuar.</p>

                    <form data-form="login" novalidate class="form-stack">
                        <div class="field-group">
                            <label for="loginEmail" class="field-label">E-mail</label>
                            <div class="input-wrapper">
                                <span class="input-icon">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                </span>
                                <input id="loginEmail" class="field-input field-input--icon" type="email" name="email" placeholder="voce@exemplo.com" required>
                            </div>
                        </div>

                        <div class="field-group">
                            <label for="loginSenha" class="field-label">Senha</label>
                            <div class="input-wrapper">
                                <span class="input-icon">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                                </span>
                                <input id="loginSenha" class="field-input field-input--icon field-input--padend" type="password" name="senha" placeholder="Sua senha" required>
                                <button type="button" class="input-toggle-pw" data-toggle-pw="loginSenha" aria-label="Mostrar senha">
                                    <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    <svg class="eye-hide d-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                </button>
                            </div>
                        </div>

                        <button class="btn btn-primary btn-block" type="submit">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                            Entrar
                        </button>
                    </form>

                    <div class="auth-footer-link">
                        Não tem conta?
                        <a href="/register">Criar cadastro</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>